# ─────────────────────────────────────────────────────────────
# BankrSynth Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ─── Bankr Platform ───────────────────────────────────────────
# Get from: https://bankr.bot
BANKR_PARTNER_KEY=your_bankr_partner_key
BANKR_LLM_KEY=your_bankr_llm_key
FEE_WALLET=0xYourWalletAddress
MY_WALLET=0xYourWalletAddress

# ─── Net Protocol ─────────────────────────────────────────────
NET_PRIVATE_KEY=your_net_private_key

# ─── GitLawb Integration ──────────────────────────────────────
# Get from: https://gitlawb.com
GITLAWB_API_KEY=your_gitlawb_api_key
GITLAWB_API_URL=https://api.gitlawb.com
GITLAWB_DID_KEY=your_did_private_key

# Local working directory for cloned repos
GITLAWB_WORKDIR=/tmp/gitlawb-repos

# ─── LLM Configuration ────────────────────────────────────────
LLM_API_URL=https://llm.bankr.bot/v1
LLM_MODEL=gpt-5-mini

# ─── Feature Flags ────────────────────────────────────────────
ENABLE_CRON=true
ENABLE_GITLAWB=true
