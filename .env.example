# ══════════════════════════════════════════════════════════════
# BANKRSYNTH MONOREPO — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in your values.
# Each app also has its own .env — this file is for shared vars.
# ══════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development

# ─── Bankr Platform ───────────────────────────────────────────
BANKR_PARTNER_KEY=your_bankr_partner_key
BANKR_LLM_KEY=your_bankr_llm_key
FEE_WALLET=0xYourWalletAddress
MY_WALLET=0xYourWalletAddress

# ─── GitLawb ──────────────────────────────────────────────────
GITLAWB_API_KEY=your_gitlawb_api_key
GITLAWB_API_URL=https://api.gitlawb.com
GITLAWB_DID_KEY=your_did_private_key
GITLAWB_WORKDIR=/tmp/gitlawb-repos

# ─── LLM ──────────────────────────────────────────────────────
LLM_API_URL=https://llm.bankr.bot/v1
LLM_MODEL=gpt-5-mini

# ─── Net Protocol ─────────────────────────────────────────────
NET_PRIVATE_KEY=your_net_private_key

# ─── Redis (for BullMQ job queues) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend ──────────────────────────────────────────────────
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ─── Feature Flags ────────────────────────────────────────────
ENABLE_CRON=true
ENABLE_GITLAWB=true
ENABLE_WEBSOCKET=true
