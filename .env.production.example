# ══════════════════════════════════════════════════════════════
# BANKRSYNTH PRODUCTION ENVIRONMENT
# Copy to .env and fill in EVERY value before deploying.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=production

# ─── Server ports ─────────────────────────────────────────────
PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ─── Public URLs (used by frontend build) ─────────────────────
# Replace with your actual domain
NEXT_PUBLIC_BACKEND_URL=https://api.YOUR_DOMAIN
NEXT_PUBLIC_WS_URL=wss://api.YOUR_DOMAIN
NEXT_PUBLIC_API_URL=https://api.YOUR_DOMAIN

# ─── CORS (backend allows requests from this origin) ──────────
FRONTEND_URL=https://YOUR_DOMAIN

# ─── Domain (for Docker SSL) ──────────────────────────────────
DOMAIN=YOUR_DOMAIN
SSL_EMAIL=your-email@example.com

# ─── Bankr Platform ───────────────────────────────────────────
# https://bankr.bot
BANKR_PARTNER_KEY=your_bankr_partner_key
BANKR_LLM_KEY=your_bankr_llm_key
FEE_WALLET=0xYourFeeWalletAddress
MY_WALLET=0xYourWalletAddress

# ─── GitLawb Integration ──────────────────────────────────────
# https://gitlawb.com
GITLAWB_API_KEY=your_gitlawb_api_key
GITLAWB_API_URL=https://api.gitlawb.com
GITLAWB_DID_KEY=your_did_private_key
GITLAWB_WORKDIR=/opt/bankrsynth/repos

# ─── LLM ──────────────────────────────────────────────────────
LLM_API_URL=https://llm.bankr.bot/v1
LLM_MODEL=gpt-5-mini

# ─── Net Protocol ─────────────────────────────────────────────
NET_PRIVATE_KEY=your_net_private_key

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
# Docker: redis://redis:6379

# ─── Feature flags ────────────────────────────────────────────
ENABLE_CRON=true
ENABLE_GITLAWB=true
ENABLE_WEBSOCKET=true
